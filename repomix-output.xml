<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <title>Fades & Facials — Site Prototype</title>

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />

  <link rel="stylesheet" href="styles.css" />
</head>
<body>
  <div id="root"></div>

  <script src="https://unpkg.com/react@18.3.1/umd/react.development.js" integrity="sha384-hD6/rw4ppMLGNu3tX5cjIb+uRZ7UkRJ6BPkLpg4hAu/6onKUg4lLsHAs9EBPT82L" crossorigin="anonymous"></script>
  <script src="https://unpkg.com/react-dom@18.3.1/umd/react-dom.development.js" integrity="sha384-u6aeetuaXnQ38mYT8rp6sbXaQe3NL9t+IBXmnYxwkUI2Hw4bsp2Wvmx4yRQF1uAm" crossorigin="anonymous"></script>
  <script src="https://unpkg.com/@babel/standalone@7.29.0/babel.min.js" integrity="sha384-m08KidiNqLdpJqLq95G/LEi8Qvjl/xUYll3QILypMoQ65QorJ9Lvtp2RXYGBFj1y" crossorigin="anonymous"></script>

  <script type="text/babel" src="tweaks-panel.jsx"></script>
  <script type="text/babel" src="shared.jsx"></script>
  <script type="text/babel" src="home.jsx"></script>
  <script type="text/babel" src="pages.jsx"></script>
  <script type="text/babel" src="admin.jsx"></script>

  <script type="text/babel">
    const { useState, useEffect } = React;

    const TWEAK_DEFAULTS = /*EDITMODE-BEGIN*/{
      "theme": "light",
      "accent": "#00F5FF",
      "motion": 1.4,
      "layout": "cinematic",
      "manifesto": "Dull is a choice. We don't carry it."
    }/*EDITMODE-END*/;

    function App() {
      const [route, setRoute] = useState("home");
      const [tw, setTw] = useTweaks(TWEAK_DEFAULTS);

      // Layout + hero state lives at the app level so admin edits propagate live
      const [activeLayout, setActiveLayoutRaw] = useState(tw.layout || "cinematic");
      const [heroUrl, setHeroUrl] = useState(HERO_MEDIA[0].url);
      const [featuredIds, setFeaturedIds] = useState(DEFAULT_FEATURED);
      const [manifesto, setManifesto] = useState(tw.manifesto);

      // Apply theme + accent + motion at the html root
      useEffect(() => {
        document.documentElement.dataset.theme = tw.theme;
        document.documentElement.style.setProperty("--theme-accent", tw.accent);
        document.documentElement.style.setProperty("--motion-scale", String(tw.motion));
      }, [tw.theme, tw.accent, tw.motion]);

      // Sync layout from tweak <-> admin
      function setActiveLayout(l) {
        setActiveLayoutRaw(l);
        setTw("layout", l);
      }
      useEffect(() => { if (tw.layout !== activeLayout) setActiveLayoutRaw(tw.layout); }, [tw.layout]);
      useEffect(() => { setManifesto(tw.manifesto); }, [tw.manifesto]);

      const isHome = route === "home";
      const isAdmin = route === "admin";

      return (
        <>
          {!isAdmin && <Navbar route={route} onNav={setRoute} isHome={isHome} />}
          {!isAdmin && <BookNowPill onNav={setRoute} />}

          {route === "home" && (
            <HomePage
              activeLayout={activeLayout}
              heroUrl={heroUrl}
              featuredIds={featuredIds}
              manifesto={manifesto}
              onNav={setRoute}
            />
          )}
          {route === "services" && <ServicesPage activeLayout={activeLayout} featuredIds={featuredIds} onNav={setRoute} />}
          {route === "gallery"  && <GalleryPage />}
          {route === "book"     && <BookPage onNav={setRoute} />}
          {route === "admin"    && (
            <AdminPage
              activeLayout={activeLayout} setActiveLayout={setActiveLayout}
              heroUrl={heroUrl} setHeroUrl={setHeroUrl}
              featuredIds={featuredIds} setFeaturedIds={setFeaturedIds}
              manifesto={manifesto} setManifesto={(m) => { setManifesto(m); setTw("manifesto", m); }}
            />
          )}

          {!isAdmin && <Footer onNav={setRoute} />}

          {/* Prototype-only page switcher (not part of the production site) */}
          <div className="proto-bar" role="navigation" aria-label="Prototype routes">
            {[
              { id: "home",     label: "Home" },
              { id: "services", label: "Services" },
              { id: "gallery",  label: "Gallery" },
              { id: "book",     label: "Book" },
            ].map(r => (
              <button key={r.id} onClick={() => setRoute(r.id)} aria-current={route === r.id}>{r.label}</button>
            ))}
            <span className="sep" />
            <button onClick={() => setRoute("admin")} aria-current={route === "admin"}>Admin</button>
          </div>

          {/* Tweaks panel */}
          <TweaksPanel title="Tweaks">
            <TweakSection title="Theme">
              <TweakRadio
                label="Surface"
                value={tw.theme}
                onChange={v => setTw("theme", v)}
                options={[
                  { value: "light", label: "Alabaster" },
                  { value: "dark",  label: "Ink" },
                ]}
              />
              <TweakColor label="Accent" value={tw.accent} onChange={v => setTw("accent", v)} />
            </TweakSection>

            <TweakSection title="Motion">
              <TweakSlider label="Motion scale" min={0} max={1.4} step={0.05} value={tw.motion} onChange={v => setTw("motion", v)} suffix="×" />
            </TweakSection>

            <TweakSection title="Dual Flicker (Home Layout)">
              <TweakRadio
                label="Active layout"
                value={tw.layout}
                onChange={v => { setTw("layout", v); setActiveLayoutRaw(v); }}
                options={[
                  { value: "cinematic", label: "Cinematic" },
                  { value: "grid",      label: "Grid" },
                  { value: "editorial", label: "Editorial" },
                ]}
              />
            </TweakSection>

            <TweakSection title="Hero Manifesto">
              <TweakText label="Italic line" value={tw.manifesto} onChange={v => setTw("manifesto", v)} />
            </TweakSection>
          </TweaksPanel>
        </>
      );
    }

    ReactDOM.createRoot(document.getElementById("root")).render(<App />);
  </script>
</body>
</html>

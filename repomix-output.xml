                <h3
                  className="font-light mb-4 leading-tight"
                  style={{
                    fontFamily: "'Bodoni Moda', serif",
                    fontSize: "clamp(2rem, 4vw, 3.5rem)",
                    color: "#F9F7F2",
                  }}
                >
                  {pair.service.name}
                </h3>
                <p
                  className="text-sm leading-relaxed mb-8 max-w-sm"

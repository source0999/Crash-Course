  // .mp4 extension OR media_type='video' both render as <video>.
  function PairMedia({
    pair,
    className,
  }: {
    pair: FeaturedPair;
    className: string;
  }) {
    if (!pair.mediaUrl) return <div className={`${className} bg-[#0b132b]`} />;
    if (isVideoMedia(pair.mediaUrl, pair.service.media_type)) {
      return (
        <video
          src={pair.mediaUrl}
          autoPlay
          muted
          loop
          playsInline
          className={className}

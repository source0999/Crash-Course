                              >
                                🗑 Delete
                              </button>
                            )}
                          </div>
                        </div>
                      )}
                    </SortableItem>
                  ))}
                </div>
              </SortableContext>
            </DndContext>
          </>
        )}
      </div>
    </main>
  );
}

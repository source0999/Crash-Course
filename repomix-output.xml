    if (error) {
      setFeedback({ type: "error", msg: "Failed to delete service." });
    } else {
      setServices((prev) => prev.filter((s) => s.id !== serviceDeleteTarget.id));
      setFeedback({ type: "success", msg: "Service deleted." });

            <AdminPage
              activeLayout="editorial" setActiveLayout={noop}
              heroUrl={heroUrl} setHeroUrl={noop}
              featuredIds={featuredIds} setFeaturedIds={noop}
              manifesto={manifesto} setManifesto={noop}
            />
          </Sheet>
        </>
      );
    }

    ReactDOM.createRoot(document.getElementById("print-root")).render(<PrintApp />);

    // Auto-print after fonts + Babel + paint
    if (window.location.hash === "#auto") {
      Promise.all([
        document.fonts ? document.fonts.ready : Promise.resolve(),
        new Promise(r => setTimeout(r, 1200)),
      ]).then(() => window.print());
    }
  </script>
</body>
</html>

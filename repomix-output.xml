  { key: 'active_layout',   value: activeLayout },
  { key: 'global_hero_url', value: heroUrl      },
  { key: 'active_theme',    value: activeTheme  },
].map(r => ({ ...r, updated_at: new Date().toISOString() })), { onConflict: 'key' });

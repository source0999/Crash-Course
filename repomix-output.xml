              border: "1px solid color-mix(in srgb, var(--theme-4) 22%, transparent)",
              boxShadow: "0 20px 60px color-mix(in srgb, var(--theme-4) 12%, transparent)",
            }}
          >
            {/* WHY: Lazy-loaded map keeps LCP clean — only loads when scrolled into view. */}
            <iframe
              src={embedSrc}
              width="100%"
              height="100%"
              style={{
                border: 0,
                minHeight: "400px",

            {t.colors.map(c => (
              <span key={c} className="w-4 h-4 rounded-full" style={{ background: c, border: "1px solid rgba(255,255,255,0.2)" }} />
            ))}
          </div>
          <span className="text-sm font-semibold" style={{ color: active ? "#7E9A7E" : "rgba(255,255,255,0.8)" }}>

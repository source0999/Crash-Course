    setServices((prev) =>
      prev.map((s) => (s.id === service.id ? { ...s, image: nextImage } : s)),
    );
    setFeedback({
      type: "success",
      msg: isCurrentlyCinematic ? "Using uploaded media." : "Cinematic mode enabled.",
    });

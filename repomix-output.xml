function FeaturedSlotModal({
  slotNumber,
  selectedServiceId,
  selectedMediaUrl,
  services,
  featuredPairings,
  mediaLibrary,
  isSaving,
  isUploadingMedia,
  onSelectService,
  onSelectMedia,
  onUploadMedia,
  onSave,
  onCancel,
}: {
  slotNumber: number;
  selectedServiceId: number | null;
  selectedMediaUrl: string | null;
  services: DbService[];
  featuredPairings: FeaturedPairing[];
  mediaLibrary: string[];
  isSaving: boolean;
  isUploadingMedia: boolean;
